<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>FixMoç - Serviços Técnicos em Moçambique</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--v:#00e676;--ve:#00b050;--vd:rgba(0,230,118,0.12);--az:#2979ff;--vm:#ff3d00;--f:#080c0e;--f2:#0f1518;--f3:#161d21;--f4:#1e272d;--b:#1f2c33;--t:#e8f0f4;--t2:#8fa3ad;--t3:#4d6672}
html,body{height:100%;background:var(--f);color:var(--t);font-family:Arial,sans-serif;font-size:15px;max-width:480px;margin:0 auto;overflow-x:hidden}
.tela{display:none;padding:20px 16px 100px;min-height:100vh}
#t-inicio{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;min-height:100vh;padding:40px 20px}
.logo{font-size:60px;font-weight:900;color:var(--v);margin-bottom:8px}
.sub{color:var(--t2);font-size:14px;margin:10px 0 40px}
.bts{display:flex;flex-direction:column;gap:12px;width:100%;max-width:300px}
h2{font-size:20px;font-weight:700;margin-bottom:16px;color:#fff}
h3{font-size:14px;font-weight:600;margin-bottom:8px;color:var(--t)}
p{font-size:14px;color:var(--t2);line-height:1.6;margin-bottom:4px}
a{color:var(--v);text-decoration:none}
button{display:block;width:100%;padding:14px;margin:8px 0;background:linear-gradient(135deg,var(--v),var(--ve));color:#000;font-size:14px;font-weight:700;border:none;border-radius:12px;cursor:pointer;touch-action:manipulation}
button:active{opacity:.8;transform:scale(.98)}
.bv{background:var(--f3)!important;border:1px solid var(--b)!important;color:var(--t2)!important}
.bp{background:linear-gradient(135deg,#ff3d00,#cc2200)!important;color:#fff!important}
.ba{background:linear-gradient(135deg,#2979ff,#1a56dd)!important;color:#fff!important}
.bc{background:linear-gradient(135deg,var(--v),var(--ve));color:#000;font-weight:700}
.bt{background:var(--f3);border:1px solid var(--b);color:var(--t)}
input,textarea,select{width:100%;padding:13px 14px;margin:6px 0;background:var(--f3);border:1px solid var(--b);border-radius:10px;color:var(--t);font-size:14px;outline:none;-webkit-appearance:none;font-family:Arial,sans-serif}
input:focus,textarea:focus,select:focus{border-color:var(--v)}
select option{background:var(--f3)}
textarea{resize:vertical;min-height:80px}
.card{background:var(--f3);border:1px solid var(--b);border-radius:14px;padding:14px;margin:10px 0}
.card-v{border-color:rgba(0,230,118,0.3);background:linear-gradient(135deg,var(--f3),rgba(0,230,118,0.04))}
.carda{border-color:rgba(255,171,0,0.4);background:rgba(255,171,0,0.04)}
.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:8px}
.grid button{background:var(--f3);border:1px solid var(--b);border-radius:12px;padding:16px 8px;font-size:13px;color:var(--t);font-weight:500;margin:0}
.grid button:active{border-color:var(--v);color:var(--v)}
.centro{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;min-height:75vh}
.icone{font-size:70px;margin-bottom:14px}
.estrelas{display:flex;justify-content:center;gap:10px;margin:14px 0}
.estrela{font-size:36px;cursor:pointer;opacity:.4;touch-action:manipulation}
.estrela.on{opacity:1}
.div{height:1px;background:var(--b);margin:14px 0}
#menu{display:none;position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:rgba(8,12,14,0.97);border-top:1px solid var(--b);justify-content:space-around;align-items:center;padding:8px 0 14px;z-index:999}
#menu button{background:none!important;border:none!important;color:var(--t3)!important;font-size:10px!important;font-weight:500!important;padding:6px 8px!important;width:auto!important;margin:0!important;display:flex!important;flex-direction:column!important;align-items:center!important;gap:3px!important;border-radius:0!important}
#menu button span{font-size:20px}
#menu button.on{color:var(--v)!important}
#toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(10px);background:var(--f4);border:1px solid var(--b);color:var(--t);padding:11px 18px;border-radius:10px;font-size:13px;font-weight:500;z-index:9999;opacity:0;transition:all .25s;pointer-events:none;max-width:300px;text-align:center;white-space:pre-line}
#toast.on{opacity:1;transform:translateX(-50%) translateY(0)}
#toast.err{border-color:var(--vm);color:#ff8a80}
#ov{display:none;position:fixed;inset:0;background:rgba(8,12,14,0.8);z-index:8888;align-items:center;justify-content:center;pointer-events:none}
#ov.on{display:flex;pointer-events:all}
.spin{width:38px;height:38px;border:3px solid var(--b);border-top-color:var(--v);border-radius:50%;animation:sp .7s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
.badge{display:inline-block;background:var(--vd);border:1px solid rgba(0,230,118,.25);color:var(--v);font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:14px;letter-spacing:1px;text-transform:uppercase}
.vu{color:#ff3d00;font-weight:600}
.vn{color:#ffab00;font-weight:600}
.vs{color:var(--v);font-weight:600}
.avatar{font-size:60px;text-align:center;margin:10px 0}
.bv2{display:inline-block;background:var(--vd);border:1px solid rgba(0,230,118,.3);color:var(--v);font-size:10px;font-weight:600;padding:3px 10px;border-radius:20px;margin-top:4px}
.chat-m{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;min-height:160px;max-height:300px;overflow-y:auto}
.mt{max-width:78%;padding:9px 13px;border-radius:14px;font-size:14px;background:var(--f4);border:1px solid var(--b);align-self:flex-start;border-bottom-left-radius:3px}
.mc{max-width:78%;padding:9px 13px;border-radius:14px;font-size:14px;background:var(--vd);border:1px solid rgba(0,230,118,.2);color:var(--v);align-self:flex-end;border-bottom-right-radius:3px}
.chat-in{display:flex;gap:8px;align-items:center}
.chat-in input{flex:1;margin:0}
.chat-in button{width:46px;min-width:46px;height:46px;padding:0;border-radius:10px;font-size:16px;margin:0;flex-shrink:0}
.serv-chip{background:var(--f3);border:1.5px solid var(--b);border-radius:12px;padding:13px 10px;font-size:13px;color:var(--t);font-weight:500;text-align:center;cursor:pointer;touch-action:manipulation;transition:all .18s;user-select:none}
.serv-chip.sel{background:var(--vd);border-color:var(--v);color:var(--v);font-weight:700}
.wstep{display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0}
.wstep span{width:28px;height:28px;border-radius:50%;background:var(--f3);border:2px solid var(--b);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--t3);transition:all .3s}
.wstep small{font-size:9px;color:var(--t3);white-space:nowrap;transition:color .3s}
.wstep.on span{background:var(--vd);border-color:var(--v);color:var(--v)}
.wstep.on small{color:var(--v)}
.wstep.done span{background:var(--ve);border-color:var(--ve);color:#000}
.wline{flex:1;height:2px;background:var(--b);margin:0 3px;margin-bottom:14px;transition:background .3s}
.wline.done{background:var(--ve)}
.req-item{padding:8px 0;border-bottom:1px solid var(--b);font-size:13px;color:var(--t);display:flex;align-items:center;gap:8px}
.req-item:last-child{border-bottom:none;padding-bottom:0}
.req-doc{color:var(--t2)}
.field-label{font-size:12px;font-weight:600;color:var(--t2);margin-bottom:2px;margin-top:4px;letter-spacing:.3px}
.timeline-item{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid var(--b)}
.timeline-item:last-child{border-bottom:none}
.tl-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:5px}
</style>
</head>
<body>
<div id="ov"><div class="spin"></div></div>
<div id="toast"></div>

<!-- INÍCIO -->
<div class="tela" id="t-inicio">
  <div class="logo">FixMoç</div>
  <div style="color:var(--v);font-size:12px;letter-spacing:2px;">MOÇAMBIQUE 🇲🇿</div>
  <p class="sub">Conectamos técnicos e clientes<br>em todo o país</p>
  <div class="bts">
    <button class="bc" onclick="escolher('cliente')">👤 Sou Cliente</button>
    <button class="bt" onclick="escolher('tecnico')">🔧 Sou Técnico</button>
  </div>
  <p style="font-size:10px;margin-top:30px;"><a href="#" onclick="irAdmin()">v2.0</a></p>
</div>

<!-- LOGIN -->
<div class="tela" id="t-login">
  <h2>Entrar na conta</h2>
  <div class="badge">⚡ Supabase Real</div>
  <input type="email" id="l-email" placeholder="O teu email" autocomplete="email">
  <input type="password" id="l-senha" placeholder="A tua senha" autocomplete="current-password">
  <button onclick="login()">Entrar</button>
  <p style="text-align:center;margin-top:10px;">Não tens conta? <a href="#" onclick="irRegisto()">Regista-te</a></p>
  <button class="bv" onclick="ir('t-inicio')">← Voltar</button>
</div>

<!-- REGISTO CLIENTE -->
<div class="tela" id="t-registo">
  <h2>👤 Criar conta Cliente</h2>
  <div class="badge">⚡ Registo rápido</div>
  <input type="text" id="r-nome" placeholder="Nome completo">
  <input type="tel" id="r-tel" placeholder="Telefone (ex: 87 479 3972)">
  <input type="email" id="r-email" placeholder="Email" autocomplete="email">
  <input type="password" id="r-senha" placeholder="Senha (mínimo 6 caracteres)" autocomplete="new-password">
  <select id="r-prov" onchange="carregarDistritos('r-prov','r-dist','r-bairro')">
    <option value="">📍 Selecciona a tua província</option>
  </select>
  <select id="r-dist" onchange="carregarBairros('r-dist','r-bairro')" style="display:none;">
    <option value="">🏙️ Selecciona o distrito</option>
  </select>
  <select id="r-bairro" style="display:none;">
    <option value="">🏘️ Selecciona o bairro</option>
  </select>
  <button onclick="registar()">✅ Criar conta</button>
  <p style="text-align:center;margin-top:8px;">És técnico? <a href="#" onclick="ir('t-reg-t')">Regista-te aqui</a></p>
  <p style="text-align:center;">Já tens conta? <a href="#" onclick="ir('t-login')">Entrar</a></p>
  <button class="bv" onclick="ir('t-inicio')">← Voltar</button>
</div>

<!-- CANDIDATURA TÉCNICO — 5 PASSOS -->
<div class="tela" id="t-reg-t" style="padding-top:16px;">

  <!-- Cabeçalho do wizard -->
  <div style="margin-bottom:22px;">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
      <button class="bv" onclick="wizVoltarOuSair()" style="width:36px;height:36px;padding:0;margin:0;font-size:18px;border-radius:10px;flex-shrink:0;">←</button>
      <div style="flex:1;">
        <div style="font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:1px;">Vaga de Técnico — FixMoç</div>
        <div style="font-size:13px;color:var(--t2);" id="wiz-label">Passo 1 de 5</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:0;margin-bottom:0;">
      <div class="wstep on" id="ws1"><span>1</span><small>Requisitos</small></div>
      <div class="wline" id="wl1"></div>
      <div class="wstep" id="ws2"><span>2</span><small>Dados</small></div>
      <div class="wline" id="wl2"></div>
      <div class="wstep" id="ws3"><span>3</span><small>Experiência</small></div>
      <div class="wline" id="wl3"></div>
      <div class="wstep" id="ws4"><span>4</span><small>Documentos</small></div>
      <div class="wline" id="wl4"></div>
      <div class="wstep" id="ws5"><span>5</span><small>Enviar</small></div>
    </div>
  </div>

  <!-- ═══ PASSO 1 — Requisitos e área de actuação ═══ -->
  <div id="wiz-p1">
    <div style="text-align:center;padding:10px 0 18px;">
      <div style="font-size:44px;margin-bottom:8px;">🔧</div>
      <h2 style="margin-bottom:6px;">Vaga de Técnico</h2>
      <p>Preenche a candidatura completa.<br>O FixMoç analisa e aprova em até 48h.</p>
    </div>

    <div class="card" style="margin-bottom:12px;">
      <div style="font-size:11px;color:var(--v);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;">📋 Requisitos obrigatórios</div>
      <div class="req-item">✅ Ter mais de 18 anos</div>
      <div class="req-item">✅ Bilhete de Identidade (BI) válido</div>
      <div class="req-item">✅ Mínimo 1 ano de experiência comprovada</div>
      <div class="req-item">✅ Telefone activo (será o teu contacto)</div>
      <div class="req-item">✅ Comprometer-se com as regras do FixMoç</div>
    </div>

    <div class="card" style="margin-bottom:12px;">
      <div style="font-size:11px;color:var(--t2);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;">📄 Documentos necessários</div>
      <div class="req-item req-doc">📎 Cópia do BI (número obrigatório)</div>
      <div class="req-item req-doc">📎 Comprovativo de experiência ou formação</div>
      <div class="req-item req-doc" style="opacity:.7;">📎 Carta de referência (opcional mas valorizada)</div>
    </div>

    <div class="card" style="margin-bottom:16px;">
      <div style="font-size:11px;color:var(--t2);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;">🔧 Qual é a tua área de trabalho?</div>
      <p style="margin-bottom:10px;font-size:13px;">Escolhe os serviços que ofereces:</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:7px;">
        <div class="serv-chip" data-v="⚡ Eletricista" onclick="toggleServ(this)">⚡ Eletricista</div>
        <div class="serv-chip" data-v="💧 Canalizador" onclick="toggleServ(this)">💧 Canalizador</div>
        <div class="serv-chip" data-v="🪚 Carpinteiro" onclick="toggleServ(this)">🪚 Carpinteiro</div>
        <div class="serv-chip" data-v="💻 Informática" onclick="toggleServ(this)">💻 Informática</div>
        <div class="serv-chip" data-v="🧱 Pedreiro" onclick="toggleServ(this)">🧱 Pedreiro</div>
        <div class="serv-chip" data-v="🧹 Limpeza" onclick="toggleServ(this)">🧹 Limpeza</div>
        <div class="serv-chip" data-v="🎨 Pintor" onclick="toggleServ(this)">🎨 Pintor</div>
        <div class="serv-chip" data-v="❄️ Ar Condicionado" onclick="toggleServ(this)">❄️ Ar Condicionado</div>
        <div class="serv-chip" data-v="🚗 Mecânico" onclick="toggleServ(this)">🚗 Mecânico</div>
        <div class="serv-chip" data-v="📺 Eletrodomésticos" onclick="toggleServ(this)">📺 Eletrodomésticos</div>
        <div class="serv-chip" data-v="🔒 Serralheiro" onclick="toggleServ(this)">🔒 Serralheiro</div>
        <div class="serv-chip" data-v="🪟 Vidraceiro" onclick="toggleServ(this)">🪟 Vidraceiro</div>
        <div class="serv-chip" data-v="🌿 Jardineiro" onclick="toggleServ(this)">🌿 Jardineiro</div>
        <div class="serv-chip" data-v="👶 Babysitter" onclick="toggleServ(this)">👶 Babysitter</div>
        <div class="serv-chip" data-v="🍳 Cozinheiro" onclick="toggleServ(this)">🍳 Cozinheiro</div>
        <div class="serv-chip" data-v="📦 Mudanças" onclick="toggleServ(this)">📦 Mudanças</div>
      </div>
      <select id="rt-prov" style="margin-top:12px;" onchange="carregarDistritos('rt-prov','rt-dist','rt-bairro')">
        <option value="">📍 Província de actuação *</option>
      </select>
      <select id="rt-dist" style="display:none;margin-top:6px;" onchange="carregarBairros('rt-dist','rt-bairro')">
        <option value="">🏙️ Selecciona o distrito</option>
      </select>
      <select id="rt-bairro" style="display:none;margin-top:6px;">
        <option value="">🏘️ Selecciona o bairro</option>
      </select>
    </div>

    <div class="card carda" style="margin-bottom:16px;">
      <p style="font-size:12px;">⚠️ Ao continuar confirmas que tens mais de 18 anos e aceitas os <a href="#" onclick="ir('t-termos')">Termos de Uso</a> do FixMoç.</p>
    </div>
    <button onclick="wizNext(2)">Continuar para os dados pessoais →</button>
    <p style="text-align:center;margin-top:10px;font-size:13px;">Já tens conta? <a href="#" onclick="ir('t-login')">Entrar aqui</a></p>
  </div>

  <!-- ═══ PASSO 2 — Dados pessoais ═══ -->
  <div id="wiz-p2" style="display:none;">
    <h2 style="margin-bottom:4px;">Dados pessoais</h2>
    <p style="margin-bottom:18px;">Informação básica da tua conta no FixMoç.</p>

    <div class="field-label">Nome completo *</div>
    <input type="text" id="rt-nome" placeholder="Ex: João Manuel Nhantumbo">

    <div class="field-label" style="margin-top:10px;">Número de telefone *</div>
    <input type="tel" id="rt-tel" placeholder="Ex: 87 479 3972">
    <p style="font-size:11px;color:var(--t3);margin-top:2px;">Este número será o teu contacto principal com os clientes.</p>

    <div class="field-label" style="margin-top:10px;">Email *</div>
    <input type="email" id="rt-email" placeholder="Ex: joao@gmail.com" autocomplete="email">

    <div class="field-label" style="margin-top:10px;">Senha *</div>
    <input type="password" id="rt-senha" placeholder="Mínimo 6 caracteres" autocomplete="new-password">

    <div class="field-label" style="margin-top:10px;">Data de nascimento *</div>
    <input type="date" id="rt-nasc" max="2007-01-01">
    <p style="font-size:11px;color:var(--t3);margin-top:2px;">Tens de ter mais de 18 anos.</p>

    <div class="field-label" style="margin-top:10px;">Género</div>
    <select id="rt-genero">
      <option value="">Selecciona (opcional)</option>
      <option value="M">Masculino</option>
      <option value="F">Feminino</option>
      <option value="O">Prefiro não dizer</option>
    </select>

    <div style="display:flex;gap:8px;margin-top:16px;">
      <button class="bv" onclick="wizBack(1)" style="flex:1;margin:0;">← Voltar</button>
      <button onclick="wizNext(3)" style="flex:2;margin:0;">Continuar →</button>
    </div>
  </div>

  <!-- ═══ PASSO 3 — Experiência profissional ═══ -->
  <div id="wiz-p3" style="display:none;">
    <h2 style="margin-bottom:4px;">Experiência profissional</h2>
    <p style="margin-bottom:18px;">Conta-nos sobre o teu trabalho. Quanto mais completo, melhor a tua candidatura.</p>

    <div class="field-label">Anos de experiência na área *</div>
    <select id="rt-exp">
      <option value="">Selecciona</option>
      <option value="1-2">1 a 2 anos</option>
      <option value="3-5">3 a 5 anos</option>
      <option value="5-10">5 a 10 anos</option>
      <option value="mais10">Mais de 10 anos</option>
    </select>

    <div class="field-label" style="margin-top:10px;">Onde já trabalhou? *</div>
    <textarea id="rt-historial" placeholder="Descreve os teus empregos ou projectos anteriores. Ex: Trabalhei 3 anos como eletricista na empresa XYZ. Fiz instalações em casas e prédios em Maputo..." rows="4"></textarea>

    <div class="field-label" style="margin-top:10px;">Formação ou certificados</div>
    <textarea id="rt-cert" placeholder="Ex: Curso de Electricidade — Centro de Formação ABC (2021)&#10;Certificado de Segurança no Trabalho — IEFP (2022)" rows="3"></textarea>
    <p style="font-size:11px;color:var(--t3);margin-top:2px;">Não é obrigatório, mas aumenta as tuas hipóteses de aprovação.</p>

    <div class="field-label" style="margin-top:10px;">Disponibilidade de horário *</div>
    <select id="rt-disp">
      <option value="">Selecciona</option>
      <option value="tempo-inteiro">Tempo inteiro (todos os dias)</option>
      <option value="manha">Só de manhã (7h — 12h)</option>
      <option value="tarde">Só de tarde (13h — 18h)</option>
      <option value="fins-semana">Fins de semana</option>
      <option value="flexivel">Horário flexível (combinamos)</option>
    </select>

    <div class="field-label" style="margin-top:10px;">Preço por hora (MT)</div>
    <input type="number" id="rt-preco" placeholder="Ex: 500 MT/hora (opcional)">

    <div class="field-label" style="margin-top:10px;">Raio de deslocação</div>
    <select id="rt-raio">
      <option value="">Selecciona</option>
      <option value="5km">Até 5 km da minha zona</option>
      <option value="10km">Até 10 km</option>
      <option value="20km">Até 20 km</option>
      <option value="provincia">Toda a província</option>
      <option value="nacional">Nacional (qualquer zona)</option>
    </select>

    <div style="display:flex;gap:8px;margin-top:16px;">
      <button class="bv" onclick="wizBack(2)" style="flex:1;margin:0;">← Voltar</button>
      <button onclick="wizNext(4)" style="flex:2;margin:0;">Continuar →</button>
    </div>
  </div>

  <!-- ═══ PASSO 4 — Documentos e referências ═══ -->
  <div id="wiz-p4" style="display:none;">
    <h2 style="margin-bottom:4px;">Documentos e referências</h2>
