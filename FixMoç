// Wizard
var wizServicos = [];
var wizPasso = 1;

window.onload = async function() {
  iniciarSelects();
  try {
    var res = await db.auth.getSession();
    if (!res.data.session) { mostrar('t-inicio'); }
  } catch(e) { mostrar('t-inicio'); }

  db.auth.onAuthStateChange(async function(ev, sess) {
    if (ev === 'SIGNED_IN' && sess) {
      A.user = sess.user;
      await carregarPerfil();
    } else if (ev === 'INITIAL_SESSION') {
      if (sess) { A.user = sess.user; await carregarPerfil(); }
      else { mostrar('t-inicio'); }
    } else if (ev === 'SIGNED_OUT') {
      A.user=null; A.perfil=null; menuHide(); mostrar('t-inicio');
    }
  });
};

async function carregarPerfil() {
  try {
    var res = await db.from('utilizadores').select('*').eq('uid', A.user.id).single();
    if (res.data) {
      A.perfil = res.data;
      if (res.data.tipo === 'tecnico') {
        if (!res.data.verificado) { mostrar('t-reg-t-ok'); return; }
        mostrar('t-tecnico');
        menuShow();
        menuOn('m-home');
        carregarPedidosTecnico();
      } else { irHome(); }
    } else { irHome(); }
  } catch(e) { irHome(); }
}

function mostrar(id) {
  document.querySelectorAll('.tela').forEach(function(t) { t.style.display='none'; });
  var el = document.getElementById(id);
  if (el) { el.style.display='block'; window.scrollTo(0,0); }
}

function menuShow() { document.getElementById('menu').style.display='flex'; }
function menuHide() { document.getElementById('menu').style.display='none'; }
function menuOn(id) {
  document.querySelectorAll('#menu button').forEach(function(b) { b.classList.remove('on'); });
  var b = document.getElementById(id); if (b) b.classList.add('on');
}

function ir(id) { mostrar(id); }

function escolher(tipo) { A.tipo=tipo; mostrar('t-login'); menuHide(); }

function irRegisto() {
  if (A.tipo === 'tecnico') {
    wizServicos = []; wizPasso = 1;
    document.querySelectorAll('.serv-chip').forEach(function(c){ c.classList.remove('sel'); });
    wizIrPasso(1);
    mostrar('t-reg-t');
  } else { mostrar('t-registo'); }
}

function irHome() {
  mostrar('t-home'); menuShow(); menuOn('m-home');
  if (A.perfil && A.perfil.nome) {
    var n = A.perfil.nome.split(' ')[0];
    document.getElementById('saudacao').textContent = 'Olá, ' + n + '! Bem-vindo ao FixMoç 👋';
  }
}

function irDef() {
  mostrar('t-def'); menuShow(); menuOn('m-def');
  if (A.user) document.getElementById('def-email').textContent = '📧 ' + A.user.email;
}

function irPerfilTecnico() {
  mostrar('t-perfil-t');
  if (A.perfil) {
    var p = A.perfil;
    document.getElementById('pf-nome').textContent = p.nome || '—';
    document.getElementById('pf-espec').textContent = '🔧 Especialidade: ' + (p.especialidade || '—');
    document.getElementById('pf-exp').textContent = '📊 Experiência: ' + (p.experiencia || '—');
    document.getElementById('pf-tel').textContent = '📞 ' + (p.tel || '—');
    document.getElementById('pf-prov').textContent = '📍 ' + (p.provincia || '—');
    document.getElementById('pf-email').textContent = '📧 ' + (p.email || '—');
    document.getElementById('pf-bio').textContent = p.bio || '—';
    document.getElementById('pf-ver').textContent = p.verificado ? '✅ Verificado pelo FixMoç' : '⏳ A aguardar verificação';
    var extra = document.getElementById('pf-extra');
    if (extra) {
      var txt = '';
      if (p.disponibilidade) txt += '<p>⏱️ Disponibilidade: '+p.disponibilidade+'</p>';
      if (p.preco_hora) txt += '<p>💰 Preço/hora: <strong style="color:var(--v)">'+p.preco_hora+' MT</strong></p>';
      if (p.raio) txt += '<p>📍 Raio de actuação: '+p.raio+'</p>';
      if (p.certificacoes) txt += '<p>🎓 Certificações: '+p.certificacoes+'</p>';
      extra.innerHTML = txt || '<p style="color:var(--t2)">—</p>';
    }
    document.getElementById('pf-aval').textContent = p.avaliacao > 0 ? '⭐ ' + p.avaliacao.toFixed(1) + ' estrelas' : '⭐ Sem avaliações';
    document.getElementById('pf-serv').textContent = '✅ Serviços feitos: ' + (p.total_servicos || 0);
    var ano = p.criado_em ? new Date(p.criado_em).getFullYear() : 2026;
    document.getElementById('pf-desde').textContent = '📅 Membro desde: ' + ano;
  }
}

function irAvaliar(pedidoId) {
  A.pedidoAval = pedidoId; A.notaAval = 0;
  document.querySelectorAll('.estrela').forEach(function(e) { e.classList.remove('on'); });
  document.getElementById('nota-aval').textContent = 'Toca nas estrelas';
  document.getElementById('comentario').value = '';
  mostrar('t-aval');
}

function irAgendar() {
  var el = document.getElementById('s-agendar');
  if (el) el.textContent = A.servico || 'Serviço';
  var dataEl = document.getElementById('a-data');
  if (dataEl) {
    var hoje = new Date().toISOString().split('T')[0];
    dataEl.min = hoje; dataEl.value = '';
  }
  mostrar('t-agendar');
}

function irPagamento() {
  document.getElementById('s-pagar').textContent = A.servico || 'Serviço';
  document.getElementById('valor').value = '';
  document.getElementById('comissao').textContent = '0 MT';
  mostrar('t-pagar');
}

function irAdmin() {
  if (!A.user) { toast('⚠️ Faz login primeiro!', 1); return; }
  carregarAdmin();
}

async function irHist() {
  mostrar('t-hist'); menuShow(); menuOn('m-ped');
  if (!A.user) return;
  var c = document.getElementById('lista-hist');
  c.innerHTML = '<p style="color:var(--t2);text-align:center;">A carregar... ⏳</p>';
  var res = await db.from('pedidos').select('*').eq('cliente_uid', A.user.id).order('criado_em', {ascending:false});
  var data = res.data;
  if (!data || data.length === 0) {
    c.innerHTML = '<div class="card"><p style="text-align:center;color:var(--t2);">Ainda não fizeste nenhum pedido.</p></div>';
    return;
  }
  c.innerHTML = '';
  data.forEach(function(p) {
    var cor = p.status==='concluido'?'#00e676':p.status==='aceite'?'#2979ff':p.status==='cancelado'?'#ff3d00':'#ffab00';
    var lbl = p.status==='concluido'?'🟢 Concluído':p.status==='aceite'?'🔵 Aceite':p.status==='cancelado'?'🔴 Cancelado':'🟡 Pendente';
    var df = p.criado_em ? new Date(p.criado_em).toLocaleDateString('pt-PT') : '—';
    var extra = '';
    if (p.status === 'pendente') extra = '<button class="bp" onclick="cancelarPedido(\'' + p.id + '\')" style="margin-top:8px;width:100%;">❌ Cancelar</button>';
    if (p.status === 'aceite') extra = '<button onclick="irAvaliar(\'' + p.id + '\')" style="margin-top:8px;width:100%;">⭐ Avaliar</button>';
    c.innerHTML += '<div class="card"><h3>' + p.servico + '</h3><p>📍 ' + p.provincia + '</p><p>📅 ' + df + (p.tecnico_nome?' · 👷 '+p.tecnico_nome:'') + '</p><p style="color:'+cor+';font-weight:600;">' + lbl + '</p>' + extra + '</div>';
  });
}

// AUTH
async function login() {
  var email = document.getElementById('l-email').value.trim();
  var senha = document.getElementById('l-senha').value;
  if (!email||!senha) { toast('⚠️ Preenche email e senha!', 1); return; }
  loading(1);
  var res = await db.auth.signInWithPassword({ email:email, password:senha });
  loading(0);
  if (res.error) toast(tradErr(res.error.message), 1);
  else toast('✅ Bem-vindo de volta!');
}

async function registar() {
  var nome = document.getElementById('r-nome').value.trim();
  var tel = document.getElementById('r-tel').value.trim();
  var email = document.getElementById('r-email').value.trim();
  var senha = document.getElementById('r-senha').value;
  var prov = document.getElementById('r-prov').value;
  var dist = document.getElementById('r-dist') ? document.getElementById('r-dist').value : '';
  var bairro = document.getElementById('r-bairro') ? document.getElementById('r-bairro').value : '';
  if (!nome||!tel||!email||!senha) { toast('⚠️ Preenche todos os campos!', 1); return; }
  if (senha.length < 6) { toast('⚠️ Senha com mínimo 6 caracteres!', 1); return; }
  loading(1);
  var res = await db.auth.signUp({ email:email, password:senha });
  if (res.error) { loading(0); toast(tradErr(res.error.message), 1); return; }
  if (res.data.user) {
    await db.from('utilizadores').insert({
      uid:res.data.user.id, nome:nome, tel:tel, email:email,
      tipo:'cliente', provincia:prov, distrito:dist, bairro:bairro, verificado:true,
      avaliacao:0, total_servicos:0, criado_em:new Date().toISOString()
    });
  }
  loading(0);
  toast('✅ Conta criada! A entrar...');
}

async function logout() {
  if (!confirm('Tens a certeza que queres sair?')) return;
  await db.auth.signOut();
  toast('👋 Sessão terminada.');
}

async function eliminarConta() {
  if (!confirm('🗑️ Eliminar conta permanentemente? Esta acção não pode ser desfeita.')) return;
  if (!A.user) return;
  loading(1);
  try {
    await db.from('agendamentos').delete().eq('cliente_uid', A.user.id);
    await db.from('avaliacoes').delete().eq('cliente_uid', A.user.id);
    await db.from('pedidos').delete().eq('cliente_uid', A.user.id);
    await db.from('utilizadores').delete().eq('uid', A.user.id);
    await db.auth.signOut();
    loading(0);
    A.user = null; A.perfil = null;
    toast('✅ Conta eliminada com sucesso.');
    setTimeout(function(){ mostrar('t-inicio'); menuHide(); }, 1500);
  } catch(e) {
    loading(0);
    toast('⚠️ Erro ao eliminar conta. Tenta novamente.', 1);
  }
}

