  if (!distSel || !bairroSel) return;
  var provId = distId.replace('dist','prov');
  var prov = document.getElementById(provId) ? document.getElementById(provId).value : '';
  var dist = distSel.value;
  if (!dist || !prov) { bairroSel.style.display='none'; return; }
  var bairros = (LOCALIZACAO[prov] && LOCALIZACAO[prov][dist]) ? LOCALIZACAO[prov][dist] : [];
  bairroSel.innerHTML = '<option value="">🏘️ Selecciona o bairro</option>';
  bairros.forEach(function(b) {
    var opt = document.createElement('option');
    opt.value = b; opt.textContent = b;
    bairroSel.appendChild(opt);
  });
  bairroSel.style.display = bairros.length > 0 ? 'block' : 'none';
}

