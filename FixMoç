function iniciarSelects() {
  var provIds = ['r-prov','rt-prov','p-prov'];
  provIds.forEach(function(id) {
    var sel = document.getElementById(id);
    if (!sel) return;
    sel.innerHTML = '<option value="">📍 Selecciona a província</option>';
    Object.keys(LOCALIZACAO).forEach(function(prov) {
      var opt = document.createElement('option');
      opt.value = prov; opt.textContent = prov;
      sel.appendChild(opt);
    });
  });
}

function carregarDistritos(provId, distId, bairroId) {
  var prov = document.getElementById(provId).value;
  var distSel = document.getElementById(distId);
  var bairroSel = document.getElementById(bairroId);
  if (!distSel) return;
  if (!prov) { distSel.style.display='none'; if(bairroSel) bairroSel.style.display='none'; return; }
  var distritos = LOCALIZACAO[prov];
  distSel.innerHTML = '<option value="">🏙️ Selecciona o distrito</option>';
  Object.keys(distritos).forEach(function(dist) {
    var opt = document.createElement('option');
    opt.value = dist; opt.textContent = dist;
    distSel.appendChild(opt);
  });
  distSel.style.display = 'block';
