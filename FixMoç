// WIZARD — 5 PASSOS
function toggleServ(el) {
  var v = el.getAttribute('data-v');
  var idx = wizServicos.indexOf(v);
  if (idx > -1) { wizServicos.splice(idx,1); el.classList.remove('sel'); }
  else { wizServicos.push(v); el.classList.add('sel'); }
}

function wizVoltarOuSair() {
  if (wizPasso === 1) ir('t-inicio');
  else wizBack(wizPasso - 1);
}

function wizNext(passo) {
  if (passo === 2) {
    if (wizServicos.length === 0) { toast('⚠️ Escolhe pelo menos 1 serviço!', 1); return; }
    if (!document.getElementById('rt-prov').value) { toast('⚠️ Selecciona a província de actuação!', 1); return; }
    if (!document.getElementById('rt-dist').value) { toast('⚠️ Selecciona o distrito!', 1); return; }
  }
  if (passo === 3) {
    var nome = document.getElementById('rt-nome').value.trim();
    var tel = document.getElementById('rt-tel').value.trim();
    var email = document.getElementById('rt-email').value.trim();
    var senha = document.getElementById('rt-senha').value;
    var nasc = document.getElementById('rt-nasc').value;
    if (!nome) { toast('⚠️ Preenche o nome completo!', 1); return; }
    if (!tel) { toast('⚠️ Preenche o número de telefone!', 1); return; }
    if (!email) { toast('⚠️ Preenche o email!', 1); return; }
    if (!senha||senha.length<6) { toast('⚠️ Senha com mínimo 6 caracteres!', 1); return; }
    if (nasc) {
      var hoje = new Date();
      var nascDate = new Date(nasc);
      var idade = hoje.getFullYear() - nascDate.getFullYear();
      var m = hoje.getMonth() < nascDate.getMonth() || (hoje.getMonth()===nascDate.getMonth()&&hoje.getDate()<nascDate.getDate());
      if (m) idade--;
      if (idade < 18) { toast('⚠️ Tens de ter mais de 18 anos!', 1); return; }
    } else { toast('⚠️ Data de nascimento obrigatória!', 1); return; }
  }
  if (passo === 4) {
    if (!document.getElementById('rt-exp').value) { toast('⚠️ Selecciona os anos de experiência!', 1); return; }
    if (!document.getElementById('rt-disp').value) { toast('⚠️ Selecciona a disponibilidade!', 1); return; }
    var hist = document.getElementById('rt-historial').value.trim();
    if (!hist||hist.length<20) { toast('⚠️ Descreve a tua experiência anterior (mínimo 20 caracteres).', 1); return; }
  }
  if (passo === 5) {
    var bi = document.getElementById('rt-bi').value.trim();
    var end = document.getElementById('rt-endereco').value.trim();
    var bio = document.getElementById('rt-bio').value.trim();
    if (!bi) { toast('⚠️ O número do BI é obrigatório!', 1); return; }
    if (!end) { toast('⚠️ Indica o teu bairro/endereço!', 1); return; }
    if (!bio||bio.length<50) { toast('⚠️ A carta de motivação deve ter pelo menos 50 caracteres.', 1); return; }
    var nome = document.getElementById('rt-nome').value.trim();
    var tel = document.getElementById('rt-tel').value.trim();
    var email = document.getElementById('rt-email').value.trim();
    var prov = document.getElementById('rt-prov').value;
    var exp = document.getElementById('rt-exp').value;
    var disp = document.getElementById('rt-disp').value;
    var preco = document.getElementById('rt-preco').value;
    var ref1 = document.getElementById('rt-ref1').value.trim();
    document.getElementById('wiz-resumo').innerHTML =
      '<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">' +
        '<div style="width:44px;height:44px;border-radius:50%;background:var(--vd);border:2px solid var(--v);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">👷</div>' +
        '<div><div style="font-size:16px;font-weight:700;color:#fff;">'+nome+'</div><div style="font-size:12px;color:var(--v);">Candidato a Técnico FixMoç</div></div>' +
      '</div>' +
      '<div class="div"></div>' +
      '<p style="font-size:12px;margin-bottom:3px;">📱 '+tel+'&nbsp;&nbsp;✉️ '+email+'</p>' +
      '<p style="font-size:12px;margin-bottom:3px;">📍 '+prov+' — '+end+'</p>' +
      '<p style="font-size:12px;margin-bottom:3px;">🔧 <strong>'+wizServicos.join(', ')+'</strong></p>' +
      '<p style="font-size:12px;margin-bottom:3px;">⏱️ '+exp+' de exp. &nbsp;|&nbsp; '+disp+'</p>' +
      (preco?'<p style="font-size:12px;margin-bottom:3px;">💰 '+preco+' MT/hora</p>':'')+
      (ref1?'<p style="font-size:12px;margin-bottom:3px;">👥 Ref: '+ref1+'</p>':'')+
      '<div class="div"></div>' +
      '<p style="font-size:12px;font-style:italic;color:var(--t2);">"'+bio.substring(0,120)+(bio.length>120?'...':'')+'"</p>';
  }
  wizIrPasso(passo);
}

function wizBack(passo) { wizIrPasso(passo); }

function wizIrPasso(passo) {
  wizPasso = passo;
  for (var i=1;i<=5;i++) {
    var p = document.getElementById('wiz-p'+i);
    if (p) p.style.display = (i===passo)?'block':'none';
    var ws = document.getElementById('ws'+i);
    if (ws) {
      ws.classList.remove('on','done');
      if (i===passo) ws.classList.add('on');
      else if (i<passo) ws.classList.add('done');
    }
    var wl = document.getElementById('wl'+i);
    if (wl) { wl.classList.remove('done'); if (i<passo) wl.classList.add('done'); }
  }
  document.getElementById('wiz-label').textContent = 'Passo '+passo+' de 5';
  window.scrollTo(0,0);
}

async function registarTecnico() {
  var nome = document.getElementById('rt-nome').value.trim();
  var tel = document.getElementById('rt-tel').value.trim();
  var email = document.getElementById('rt-email').value.trim();
  var senha = document.getElementById('rt-senha').value;
  var prov = document.getElementById('rt-prov').value;
  var bio = document.getElementById('rt-bio').value.trim();
  var bi = document.getElementById('rt-bi').value.trim();
  var disp = document.getElementById('rt-disp').value;
  var preco = document.getElementById('rt-preco').value;
  var raio = document.getElementById('rt-raio').value;
  var cert = document.getElementById('rt-cert').value.trim();
  var hist = document.getElementById('rt-historial').value.trim();
  var end = document.getElementById('rt-endereco').value.trim();
  var refNome = document.getElementById('rt-ref1').value.trim();
  var refRel = document.getElementById('rt-refrel').value;
  var refTel = document.getElementById('rt-ref1tel').value.trim();
  var exp = document.getElementById('rt-exp').value;
  var nasc = document.getElementById('rt-nasc').value;
  var genero = document.getElementById('rt-genero').value;
  var espec = wizServicos.length > 0 ? wizServicos[0] : '';
  var todosServicos = wizServicos.join(', ');
  loading(1);
  var res = await db.auth.signUp({ email:email, password:senha });
  if (res.error) { loading(0); toast(tradErr(res.error.message), 1); return; }
  if (res.data.user) {
    var ins = await db.from('utilizadores').insert({
      uid:res.data.user.id, nome:nome, tel:tel, email:email,
      tipo:'tecnico', provincia:prov, verificado:false,
      especialidade:espec, todos_servicos:todosServicos,
      experiencia:exp, bio:bio, historial:hist,
      bi:bi, endereco:end,
      disponibilidade:disp, preco_hora:preco?parseInt(preco):null,
      raio:raio, certificacoes:cert||null,
      data_nascimento:nasc||null, genero:genero||null,
      referencia_nome:refNome||null, referencia_relacao:refRel||null,
      referencia_tel:refTel||null,
      avaliacao:0, total_servicos:0,
      criado_em:new Date().toISOString()
    });
    if (ins.error) { loading(0); toast('Erro ao guardar perfil: ' + (ins.error.message||'tente novamente'), 1); return; }
  }
  loading(0);
  mostrar('t-reg-t-ok');
  toast('🚀 Candidatura enviada com sucesso!');
}

// UTILS
function tradErr(msg) {
  if (msg.indexOf('Invalid login')>-1) return '⚠️ Email ou senha incorrectos.';
  if (msg.indexOf('already registered')>-1) return '⚠️ Email já registado.';
  if (msg.indexOf('Password')>-1) return '⚠️ Senha com mínimo 6 caracteres.';
  if (msg.indexOf('email')>-1) return '⚠️ Email inválido.';
  return '⚠️ ' + msg;
}

function toast(msg, err) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.className = 'on'+(err?' err':'');
  clearTimeout(window._tt);
  window._tt = setTimeout(function(){t.className='';}, 3500);
}

function loading(show) {
  document.getElementById('ov').className = show ? 'on' : '';
}
</script>
